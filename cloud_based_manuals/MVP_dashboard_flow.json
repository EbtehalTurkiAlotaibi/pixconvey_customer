    {
        "id": "0e75bd183b2d5d68",
        "type": "function",
        "z": "930bc2d47c250ff6",
        "name": "initDelivery",
        "func": "const start = flow.get(\"startPoint\");\nconst end = flow.get(\"endPoint\");\nconst robot = flow.get(\"robot\");\n\nflow.set(\"startJourney-\" + robot, msg.payload);\n\nmsg.payload = {\n    \"timestamp\": msg.payload, \n    \"taskId\": 123456, \n    \"businessType\": 3, \n    \"stopPointList\": [\n        { \"nodeID\": start }, \n        { \"nodeID\": end }\n        ],\n    };\n\nmsg.topic = \"/cloud/driving/path/\"+robot;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
