        "type": "function",
        "z": "930bc2d47c250ff6",
        "name": "function 123",
        "func": "var electric = parseInt(msg.payload.vehiceData.electric);\n\n\nvar color1 = \"#00ff00\"; // Green\nvar color2 = \"#f5da42\"; // Yellow\nvar color3 = \"#ff0000\"; // Red\n\nvar waveColor;\nif (electric < 40) {\n    waveColor = color3;\n} else if (electric < 70) {\n    waveColor = color2;\n} else {\n    waveColor = color1;\n}\n\nmsg.ui_control = {\n    \"options\":{\n        \"waveColor\": waveColor\n    }\n};\n\nmsg.payload = electric;\nreturn msg;",
        "outputs": 1,
